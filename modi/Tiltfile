# Tiltfile

# 1) k8s yaml 로드 (kustomize overlay 사용)
env_path = 'k8s/overlays/kind/.env'
if not os.path.exists(env_path):
  fail('Missing %s. Copy your .env to k8s/overlays/kind/.env before running Tilt.' % env_path)

k8s_yaml(kustomize('k8s/overlays/kind'))

# 2) 로컬 도커 이미지 빌드(각 서비스별)
shared_paths = [
  'build.gradle',
  'settings.gradle',
  'gradle',
  'gradlew',
  'gradle.properties',
  'common',
  'common-security',
  'common-notification',
  'common-openapi',
  'common-kafka',
]

ignore_paths = [
  '**/build/**',
  '**/.gradle/**',
]

def only_paths(service_dir):
  return shared_paths + [service_dir]

docker_build(
  'modi/modi-discovery:local',
  context='.',
  dockerfile='modi-discovery/Dockerfile',
  build_args={'MODULE': 'modi-discovery'},
  only=only_paths('modi-discovery'),
  ignore=ignore_paths,
)

docker_build(
  'modi/modi-config:local',
  context='.',
  dockerfile='modi-config/Dockerfile',
  build_args={'MODULE': 'modi-config'},
  only=only_paths('modi-config'),
  ignore=ignore_paths,
)

docker_build(
  'modi/modi-gateway:local',
  context='.',
  dockerfile='modi-gateway/Dockerfile',
  build_args={'MODULE': 'modi-gateway'},
  only=only_paths('modi-gateway'),
  ignore=ignore_paths,
)

docker_build(
  'modi/account-service:local',
  context='.',
  dockerfile='account-service/Dockerfile',
  build_args={'MODULE': 'account-service'},
  only=only_paths('account-service'),
  ignore=ignore_paths,
)

docker_build(
  'modi/product-service:local',
  context='.',
  dockerfile='product-service/Dockerfile',
  build_args={'MODULE': 'product-service'},
  only=only_paths('product-service'),
  ignore=ignore_paths,
)

docker_build(
  'modi/rental-service:local',
  context='.',
  dockerfile='rental-service/Dockerfile',
  build_args={'MODULE': 'rental-service'},
  only=only_paths('rental-service'),
  ignore=ignore_paths,
)

docker_build(
  'modi/seller-service:local',
  context='.',
  dockerfile='seller-service/Dockerfile',
  build_args={'MODULE': 'seller-service'},
  only=only_paths('seller-service'),
  ignore=ignore_paths,
)

docker_build(
  'modi/member-service:local',
  context='.',
  dockerfile='member-service/Dockerfile',
  build_args={'MODULE': 'member-service'},
  only=only_paths('member-service'),
  ignore=ignore_paths,
)

# 3) k8s 리소스(이름은 매니페스트 metadata.name와 맞춰야 함)
# 특정 리소스만 띄우고 싶으면:
# tilt up -- --services=modi-config,modi-gateway
config.define_string_list('services')
cfg = config.parse()
only_services = cfg.get('services', [])

def auto_init_for(name):
  return (not only_services) or (name in only_services)

k8s_resource('pgvector', auto_init=auto_init_for('pgvector'), port_forwards=5432)
k8s_resource('redis', auto_init=auto_init_for('redis'))
k8s_resource('elasticsearch', auto_init=auto_init_for('elasticsearch'))

k8s_resource('modi-discovery', port_forwards=8761, auto_init=auto_init_for('modi-discovery'))
k8s_resource('modi-config', port_forwards=8888, auto_init=auto_init_for('modi-config'))
k8s_resource('modi-gateway', port_forwards=8080, auto_init=auto_init_for('modi-gateway'))

k8s_resource('account-service', auto_init=auto_init_for('account-service'))
k8s_resource('product-service', auto_init=auto_init_for('product-service'))
k8s_resource('rental-service', auto_init=auto_init_for('rental-service'))
k8s_resource('seller-service', auto_init=auto_init_for('seller-service'))
k8s_resource('member-service', auto_init=auto_init_for('member-service'))
