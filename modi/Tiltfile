# Tiltfile

# 0) 공통 설정
config.define_string('k8s_context')
config.define_string('registry_host')
config.define_string('registry_port')
config.define_string_list('services')
cfg = config.parse()
ctx = cfg.get('k8s_context', '') or 'k3d-modi'
k8s_context(ctx)

registry_host = cfg.get('registry_host', '')
registry_port = cfg.get('registry_port', '5001')
if registry_host:
  default_registry('%s:%s' % (registry_host, registry_port))
elif ctx.startswith('k3d-'):
  cluster_name = ctx[len('k3d-'):]
  default_registry('k3d-%s-registry:%s' % (cluster_name, registry_port))

# 1) k8s yaml 로드 (kustomize overlay 사용)
env_path = 'k8s/overlays/k3s/.env'
if not os.path.exists(env_path):
  fail('Missing %s. Copy your .env to k8s/overlays/k3s/.env before running Tilt.' % env_path)

k8s_yaml(kustomize('k8s/overlays/k3s'))

# 2) 로컬 도커 이미지 빌드(각 서비스별)
shared_paths = [
  'build.gradle',
  'settings.gradle',
  'gradle',
  'gradlew',
  'gradle.properties',
  'common',
  'common-logging',
  'common-security',
  'common-notification',
  'common-openapi',
  'common-kafka'
]

ignore_paths = [
  '**/build/**',
  '**/.gradle/**',
]

def only_paths(service_dir):
  return shared_paths + [service_dir]

docker_build(
  'modi/modi-discovery:local',
  context='.',
  dockerfile='modi-discovery/Dockerfile',
  build_args={'MODULE': 'modi-discovery'},
  only=only_paths('modi-discovery'),
  ignore=ignore_paths,
)

docker_build(
  'modi/modi-config:local',
  context='.',
  dockerfile='modi-config/Dockerfile',
  build_args={'MODULE': 'modi-config'},
  only=only_paths('modi-config'),
  ignore=ignore_paths,
)

docker_build(
  'modi/modi-gateway:local',
  context='.',
  dockerfile='modi-gateway/Dockerfile',
  build_args={'MODULE': 'modi-gateway'},
  only=only_paths('modi-gateway'),
  ignore=ignore_paths,
)

docker_build(
  'modi/account-service:local',
  context='.',
  dockerfile='account-service/Dockerfile',
  build_args={'MODULE': 'account-service'},
  only=only_paths('account-service'),
  ignore=ignore_paths,
)

docker_build(
